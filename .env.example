# ─── FICHIER RACINE — lu par docker-compose.dev.yml ──────────────────────────
# Copier en .env : cp .env.example .env

# ─── API ──────────────────────────────────────────────────────────────────────
API_NODE_ENV=development
API_PORT=3001
# URL interne Docker : service "postgres" = nom du container postgres
API_DATABASE_URL=postgres://myquizz:myquizz@postgres:5432/myquizz_db
ALLOWED_ORIGINS=http://localhost:5173
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_secret_min_32_chars

# ─── CLIENT ───────────────────────────────────────────────────────────────────
CLIENT_PORT=5173
# URL appelée depuis le navigateur (hors Docker) → pointe sur API_PORT exposé
VITE_API_BASE_URL=http://localhost:3001/api

# ─── LOGS SERVICE ─────────────────────────────────────────────────────────────
LOGS_NODE_ENV=development
LOGS_PORT=3002
# URL interne Docker : service "mongodb"
LOGS_DATABASE_URL=mongodb://admin:admin@mongodb:27017/myquizz_logs?authSource=admin
# Nom + port interne utilisé par l'API pour joindre le logs-service
LOGS_SERVICE_HOST=logs-service
LOGS_SERVICE_PORT=3000

# ─── FILES SERVICE ────────────────────────────────────────────────────────────
FILES_NODE_ENV=development
FILES_PORT=3003
# URL interne Docker : service "files-postgres"
FILES_DATABASE_URL=postgres://fileservice:fileservice@files-postgres:5432/fileservice
# Nom + port interne utilisé par l'API pour joindre le files-service
FILES_SERVICE_HOST=files-service
FILES_SERVICE_PORT=3000

# ─── POSTGRESQL (BDD principale) ──────────────────────────────────────────────
# Port exposé sur l'hôte (ex: accès via Adminer ou psql local)
PG_PORT=5432

# ─── POSTGRESQL (files-service) ───────────────────────────────────────────────
# Port différent pour éviter le conflit avec la BDD principale
FILES_PG_PORT=5433

# ─── ADMINER ──────────────────────────────────────────────────────────────────
ADMINER_PORT=8080

# ─── MONGODB ──────────────────────────────────────────────────────────────────
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_INITDB_DATABASE=myquizz_logs

# ─── MONGO EXPRESS ────────────────────────────────────────────────────────────
MONGO_EXPRESS_PORT=8081
