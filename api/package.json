{
  "name": "api",
  "type": "module",
  "scripts": {
    "======= Pour la prod =======": "========================",
    "start": "node dist/index.js",
    "build": "tsc",
    "docker:start": "npm run db:migrate:deploy && npm run docker:seed && npm start",
    "docker:seed": "tsx ./src/models/seeding.ts",
    "======= Pour le dev ========": "========================",
    "dev": "tsx --watch --env-file=.env index.ts",
    "test:unit": "tsx --test ./**/*.unit.test.ts",
    "test:spec": "tsx --test --env-file=./test/config/.env.test --import ./test/config/global-setup.ts --experimental-test-isolation=none ./**/*.spec.test.ts",
    "test:spec:docker": "tsx --test --env-file=./test/config/.env.test.docker --import ./test/config/bootstrap.ts --import ./test/config/global-setup.ts --experimental-test-isolation=none ./**/*.spec.test.ts",
    "test": "npm run test:unit && npm run test:spec",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "======= Pour la BDD ========": "========================",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate",
    "db:seed": "tsx --env-file=.env ./src/models/seeding.ts",
    "db:reset": "npm run db:migrate:reset && npm run db:seed",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prisma/client": "^7.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.21.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  }
}
