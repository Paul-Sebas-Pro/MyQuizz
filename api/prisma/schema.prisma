datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

// Enumeration pour éviter les erreurs de donnée
enum Role {
  member
  author
  admin
}

model User {
  id Int @id @default(autoincrement())

  firstname String
  lastname  String
  email     String @unique()
  password  String

  // Role des utilisateurs
  role Role @default(member)

  refresh_tokens RefreshToken[]
  quizzes        Quiz[]
  attempts       Attempt[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("user") // Correspondance entre le model User dans le code et la table "user" dans la BDD
}

model Level {
  id Int @id @default(autoincrement())

  name String @unique()

  questions Question[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model RefreshToken {
  id Int @id @default(autoincrement())

  token String

  user    User @relation(fields: [user_id], references: [id])
  user_id Int

  issued_at  DateTime @default(now())
  expires_at DateTime

  @@map("refresh_token")
}

model Quiz {
  id Int @id @default(autoincrement())

  title       String
  description String?
  published_at DateTime?

  author    User @relation(fields: [author_id], references: [id])
  author_id Int

  questions Question[]
  tags      QuizTag[]
  attempts  Attempt[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("quiz")
}

model Question {
  id Int @id @default(autoincrement())

  statement String
  anecdote  String?
  link      String?

  quiz    Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  quiz_id Int

  level    Level @relation(fields: [level_id], references: [id])
  level_id Int

  answers Answer[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("question")
}

model Answer {
  id Int @id @default(autoincrement())

  description String
  is_valid    Boolean @default(false)

  question    Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  question_id Int

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("answer")
}

model Tag {
  id Int @id @default(autoincrement())

  name String @unique

  parent    Tag?  @relation("TagHierarchy", fields: [parent_id], references: [id])
  parent_id Int?
  children  Tag[] @relation("TagHierarchy")

  quizzes QuizTag[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("tag")
}

model QuizTag {
  id Int @id @default(autoincrement())

  quiz    Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  quiz_id Int

  tag    Tag @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  tag_id Int

  @@unique([quiz_id, tag_id])
  @@map("quiz_tag")
}

model Attempt {
  id Int @id @default(autoincrement())

  score     Int
  score_max Int

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  quiz    Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  quiz_id Int

  created_at DateTime @default(now())

  @@map("attempt")
}