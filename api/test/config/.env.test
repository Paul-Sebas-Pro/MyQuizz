
# BDD de test

POSTGRES_USER=myquizztest
POSTGRES_PASSWORD=myquizztest
POSTGRES_DB=myquizztest_db
# on utilise un port != de celui pour la BDD de prod
POSTGRES_PORT=5438

# Serveur de test
PORT=7357
DATABASE_URL=postgres://myquizztest:myquizztest@localhost:5438/myquizztest_db

# JWT secret dédié aux tests
JWT_SECRET=test-jwt-secret-for-integration-tests