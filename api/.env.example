# ─── API — DEV LOCAL (sans Docker) ───────────────────────────────────────────
# Pour dev Docker, utiliser le .env à la racine du projet.
# Copier en .env : cp .env.example .env

NODE_ENV=development
PORT=3001

# PostgreSQL local (psql ou container Docker standalone)
# Si Docker standalone : docker run -p 5432:5432 -e POSTGRES_USER=myquizz ...
DATABASE_URL=postgres://myquizz:myquizz@localhost:5432/myquizz_db

# Origine(s) autorisées par CORS (séparées par virgules)
ALLOWED_ORIGINS=http://localhost:5173

# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_secret_min_32_chars

# Microservices (localhost si lancés séparément hors Docker)
LOGS_SERVICE_HOST=localhost
LOGS_SERVICE_PORT=3002
FILES_SERVICE_HOST=localhost
FILES_SERVICE_PORT=3003
