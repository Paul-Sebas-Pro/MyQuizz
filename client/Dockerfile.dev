FROM node:22-alpine

WORKDIR /app

# VITE_API_BASE_URL passé en build arg depuis docker-compose
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

COPY package*.json ./

RUN npm install

# --host expose Vite hors du container (accessible depuis l'hôte)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
